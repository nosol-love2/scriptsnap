  "answer_container": ".font-claude-response",
  "answer_container_alt": "[data-testid='chat-message-content']",

  "stop_button": "button[aria-label='Stop Response'], button[aria-label='Stop response']",
  "stop_button_alt": "button[aria-label='응답 중지'], button[data-testid='stop-button']",

  "loading_indicator": "[data-testid='message-loading']",
  "loading_indicator_alt": ".animate-pulse",

  "login_required": "a[href*='login'], button:has-text('Log in'), button:has-text('Sign in')",
  "error_message": "[role='alert'], .error-message"
